# Leave empty to use Vite dev proxy (/api -> http://localhost:4001).
# If set, use origin only (http://host:port) — not .../api (paths already include /api/...).
VITE_API_URL=

# Must match server PORT in server/.env (default 4001). If you see ECONNREFUSED, start the API or fix this.
# VITE_PROXY_TARGET=http://127.0.0.1:4001
