PORT=4001
# Local MongoDB (default port 27017). Start "MongoDB" as a Windows service after install.
# For MongoDB Atlas in the cloud, replace with your mongodb+srv://... string.
MONGO_URI=mongodb://127.0.0.1:27017/robotics_edu

JWT_SECRET=change-this-to-a-long-random-secret
CLIENT_ORIGIN=http://localhost:5173
# Absolute path recommended in production. Must be persistent (same folder where files were uploaded);
# if this changes, existing DB file paths may show "File missing" on download.
UPLOAD_DIR=./uploads

# Optional: AI grading via Google Gemini (free tier) — https://aistudio.google.com/apikey
# Put the key only in server/.env (not client). After saving, restart `npm run dev`.
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
#
# Verify: GET http://localhost:PORT/api/health  → ai.geminiKeyConfigured, ai.provider
# Or run:  cd server && npm run test:gemini

# ─── S3-compatible cloud storage (Cloudflare R2 / AWS S3) ───
# If ALL five values below are set, file uploads go to cloud storage instead of local disk.
# This is REQUIRED for deployed servers on Render/Railway (ephemeral filesystem).
# Cloudflare R2 (free 10 GB): https://dash.cloudflare.com → R2 → Create bucket → Manage R2 API Tokens
# AWS S3: https://console.aws.amazon.com/s3/
# S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com   (R2) or https://s3.<region>.amazonaws.com (AWS)
# S3_REGION=auto                                               (R2) or your AWS region (e.g. us-east-1)
# S3_BUCKET=your-bucket-name
# S3_ACCESS_KEY_ID=your-access-key-id
# S3_SECRET_ACCESS_KEY=your-secret-access-key
# S3_PUBLIC_URL=                                               (optional) public URL for direct access
