PORT=4001
# Local MongoDB (default port 27017). Start "MongoDB" as a Windows service after install.
# For MongoDB Atlas in the cloud, replace with your mongodb+srv://... string.
MONGO_URI=mongodb://127.0.0.1:27017/robotics_edu

JWT_SECRET=change-this-to-a-long-random-secret
CLIENT_ORIGIN=http://localhost:5173
UPLOAD_DIR=./uploads

# Optional: AI grading via Google Gemini (free tier) — https://aistudio.google.com/apikey
# Put the key only in server/.env (not client). After saving, restart `npm run dev`.
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
#
# Verify: GET http://localhost:PORT/api/health  → ai.geminiKeyConfigured, ai.provider
# Or run:  cd server && npm run test:gemini
